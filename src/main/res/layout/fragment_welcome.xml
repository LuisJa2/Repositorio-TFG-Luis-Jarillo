<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="24dp">

    <!-- Logo Area -->
    <LinearLayout
        android:id="@+id/logo_area"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/sport_icons_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Arena Mix Logo Text -->
        <TextView
            android:id="@+id/logo_arena"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ARENA"
            android:textSize="42sp"
            android:textStyle="bold"
            android:textColor="@color/orange_primary"
            android:letterSpacing="0.1"/>

        <TextView
            android:id="@+id/logo_mix"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MIX"
            android:textSize="42sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:letterSpacing="0.1"
            android:layout_marginTop="-8dp"/>

    </LinearLayout>

    <!-- Sport Icons Label -->
    <TextView
        android:id="@+id/sport_icons_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/customize_arena"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        app:layout_constraintBottom_toTopOf="@id/sport_icons_row"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp"/>

    <!-- Sport Icons Row -->
    <LinearLayout
        android:id="@+id/sport_icons_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toTopOf="@id/btn_explore"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/sport_futbol"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_sport_card"
            android:layout_marginEnd="8dp">
            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_soccer"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/futbol"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sport_padel"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_sport_card_selected"
            android:layout_marginEnd="8dp">
            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_padel"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/padel"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sport_basket"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_sport_card">
            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_basketball"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/basket"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Explore Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_explore"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="@string/explore_tournaments"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="14sp"
        style="@style/Widget.ArenaMix.Button.Orange"
        app:layout_constraintBottom_toTopOf="@id/auth_row"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp"/>

    <!-- Auth Row -->
    <LinearLayout
        android:id="@+id/auth_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toTopOf="@id/tv_guest"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/btn_register"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/register"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:padding="8dp"/>

        <View
            android:layout_width="1dp"
            android:layout_height="16dp"
            android:background="@color/divider"
            android:layout_marginHorizontal="8dp"/>

        <TextView
            android:id="@+id/btn_login"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/login"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:padding="8dp"/>

    </LinearLayout>

    <!-- Guest Link -->
    <TextView
        android:id="@+id/tv_guest"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/continue_guest"
        android:textSize="13sp"
        android:textColor="@color/text_hint"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
